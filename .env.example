# Your Gemini API key, get one for free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- CORS / frontend settings ---
# Write plain URLs only. NO brackets, NO quotes (e.g. ["http://..."] is WRONG).
# Multiple values are separated by a comma, with no space after the comma,
# e.g. http://127.0.0.1:5500,http://localhost:4200

# The exact origin (protocol + host + port) your frontend runs on.
# Common dev ports: VS Code Live Server = 5500, Angular = 4200, React = 3000, Vite = 5173
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500

# Hostnames this Django backend itself accepts requests for.
ALLOWED_HOSTS=127.0.0.1,localhost

# Same origin(s) as CORS_ALLOWED_ORIGINS above, needed for POST/PATCH/DELETE requests.
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5500
